# OpenRouter API key (required for all AI features)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default chat model for Q&A
NEXT_PUBLIC_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Embedding model (default: "prompt" — uses OpenRouter chat for free prompt-based embeddings)
# Set to any model ID to use OpenRouter's embeddings API endpoint instead, e.g.:
# EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_MODEL=jina/jina-embeddings-v2-base-en:free
EMBEDDING_MODEL=prompt

# Vector store (default: in-memory — data lost on restart)
# Set PINECONE_API_KEY to use Pinecone as the vector store instead
PINECONE_API_KEY=
PINECONE_INDEX=rag-embeddings
