{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/agent", "dest": "/client/dist/index.html" },
    { "src": "/ignored-agent", "dest": "/client/dist/index.html" },
    { "src": "/low-score", "dest": "/client/dist/index.html" },
    { "src": "/(.*)", "dest": "/client/dist/$1" }
  ]
}
